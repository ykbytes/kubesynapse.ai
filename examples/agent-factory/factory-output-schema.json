{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KubeSynapseFactoryBlueprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "factory_mode",
    "expanded_spec",
    "intent_summary",
    "demand_model",
    "architecture_decision",
    "delivery_plan",
    "resources_to_create",
    "manifests",
    "supporting_deliverables",
    "execution_plan",
    "deploy_and_verify",
    "review_status",
    "approval_required",
    "resource_names"
  ],
  "properties": {
    "factory_mode": {
      "type": "string",
      "enum": [
        "lightweight-draft",
        "governed-bundle",
        "fully-autonomous"
      ]
    },
    "expanded_spec": {
      "type": "object",
      "description": "The full expanded specification produced by the analyst agent, stored here for traceability. Contains the objective, requirements, capabilities, architecture recommendation, task decomposition, and quality criteria that drove the bundle design.",
      "required": [
        "objective",
        "requirements",
        "capabilities_needed",
        "architecture_recommendation",
        "task_decomposition",
        "quality_and_verification"
      ],
      "properties": {
        "objective": {
          "type": "object",
          "description": "Business objective, end state, target audience, and scope boundaries."
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "title", "description", "scenarios"],
            "properties": {
              "id": { "type": "string" },
              "capability_area": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "priority": { "type": "string" },
              "scenarios": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "object" }
              }
            }
          }
        },
        "capabilities_needed": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "object" }
        },
        "architecture_recommendation": {
          "type": "object",
          "description": "Shape, rationale, specialist roles, interaction pattern, and approval gates."
        },
        "task_decomposition": {
          "type": "object",
          "description": "Artifact structure and phased task breakdown with dependencies."
        },
        "quality_and_verification": {
          "type": "object",
          "description": "Acceptance criteria, test strategy, smoke checks, success evidence, and failure handling."
        },
        "confidence_level": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Analyst confidence in the spec. Low means significant assumptions were made due to vague input."
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Unresolved questions the analyst could not answer from the input alone."
        }
      }
    },
    "intent_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal",
        "primary_outcomes",
        "target_users",
        "key_constraints",
        "assumptions"
      ],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "primary_outcomes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "target_users": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "key_constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "demand_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_class",
        "primary_domain_pack",
        "secondary_domain_packs",
        "autonomy_target",
        "success_evidence",
        "key_risks"
      ],
      "properties": {
        "request_class": {
          "type": "string",
          "description": "Free-form classification of the request type, derived from the expanded specification. Examples: application, book-report, presentation, automation, resource-edit, learning-system, research-pipeline, creative-project, compliance-tracker, etc.",
          "minLength": 1
        },
        "primary_domain_pack": {
          "type": "string",
          "description": "The primary capability category derived from the spec. May be a legacy domain pack name (application-studio, narrative-publishing, presentation-studio, automation-orchestrator, surgical-edit) or a custom category matching the identified capabilities.",
          "minLength": 1
        },
        "secondary_domain_packs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "capabilities": {
          "type": "array",
          "description": "List of capabilities identified by the analyst's expanded specification that drove the bundle design. Examples: code-generation, research, authoring, data-processing, presentation, automation, review-and-qa, deployment, testing, human-interaction, domain-specialization.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "autonomy_target": {
          "type": "string",
          "enum": [
            "draft-only",
            "review-ready",
            "deploy-ready",
            "run-ready"
          ]
        },
        "success_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "key_risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "architecture_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_shape",
        "reason",
        "alternatives_rejected",
        "specialist_roles"
      ],
      "properties": {
        "selected_shape": {
          "type": "string",
          "enum": [
            "single-agent",
            "multi-agent-bundle",
            "multi-agent-bundle-plus-workflow"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "alternatives_rejected": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "specialist_roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "responsibility",
              "runtime",
              "tooling"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "responsibility": {
                "type": "string",
                "minLength": 1
              },
              "runtime": {
                "type": "string",
                "enum": [
                  "opencode"
                ]
              },
              "tooling": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "delivery_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deliverable_family",
        "final_artifacts",
        "operating_sequence",
        "test_strategy",
        "acceptance_story"
      ],
      "properties": {
        "deliverable_family": {
          "type": "string",
          "minLength": 1
        },
        "final_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "kind",
              "description",
              "verification"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "verification": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "operating_sequence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "test_strategy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "acceptance_story": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "resources_to_create": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "name",
          "namespace",
          "purpose"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "namespace": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "manifests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "combined_yaml"
      ],
      "properties": {
        "combined_yaml": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "supporting_deliverables": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_readme_markdown",
        "verification_runbook_markdown",
        "example_requests",
        "acceptance_criteria",
        "evaluation_plan",
        "prompt_design_notes"
      ],
      "properties": {
        "operator_readme_markdown": {
          "type": "string",
          "minLength": 1
        },
        "verification_runbook_markdown": {
          "type": "string",
          "minLength": 1
        },
        "example_requests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evaluation_plan": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prompt_design_notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "execution_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_mode",
        "runnable",
        "success_checks",
        "evidence_to_capture",
        "blockers"
      ],
      "properties": {
        "execution_mode": {
          "type": "string",
          "enum": [
            "design-only",
            "bundle-for-handoff",
            "deploy-only",
            "deploy-and-run"
          ]
        },
        "runnable": {
          "type": "boolean"
        },
        "generated_workflow_name": {
          "type": "string",
          "minLength": 1
        },
        "generated_workflow_input": {
          "type": "string",
          "minLength": 1
        },
        "success_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_to_capture": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "if": {
        "properties": { "runnable": { "const": true } },
        "required": ["runnable"]
      },
      "then": {
        "required": [
          "execution_mode",
          "runnable",
          "generated_workflow_name",
          "generated_workflow_input",
          "success_checks",
          "evidence_to_capture",
          "blockers"
        ]
      }
    },
    "deploy_and_verify": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "apply_order",
        "verification_checks",
        "rollback_steps",
        "follow_up_evals"
      ],
      "properties": {
        "apply_order": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verification_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rollback_steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "follow_up_evals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "review_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "final_verdict",
        "rework_rounds_attempted",
        "blocking_issues",
        "deploy_permitted",
        "run_permitted",
        "summary"
      ],
      "properties": {
        "final_verdict": {
          "type": "string",
          "enum": [
            "draft-only",
            "pending-review",
            "approved",
            "needs-work"
          ]
        },
        "rework_rounds_attempted": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "blocking_issues": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deploy_permitted": {
          "type": "boolean"
        },
        "run_permitted": {
          "type": "boolean"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "approval_required": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deploy",
        "edit_live_resources",
        "run_generated_workflow",
        "reason"
      ],
      "properties": {
        "deploy": {
          "type": "boolean"
        },
        "edit_live_resources": {
          "type": "boolean"
        },
        "run_generated_workflow": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "resource_names": {
      "type": "array",
      "minItems": 1,
      "description": "Canonical bundle root path plus stable resource and workflow names that identify the final output.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}