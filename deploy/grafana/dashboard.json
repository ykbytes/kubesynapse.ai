  "panels": [
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": true
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 80}]},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "expr": "sum(rate(KUBESYNAPSE_gateway_request_total[5m])) by (handler)",
          "refId": "A"
        }
      ],
      "title": "API Gateway Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"align": "auto", "displayMode": "auto"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 5}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"showHeader": true},
      "targets": [
        {
          "expr": "sum(rate(KUBESYNAPSE_gateway_request_latency_seconds_count{status=~\"5..\"}[5m])) / sum(rate(KUBESYNAPSE_gateway_request_latency_seconds_count[5m])) * 100",
          "refId": "A"
        }
      ],
      "title": "API Gateway Error Rate (%)",
      "type": "stat"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(KUBESYNAPSE_gateway_request_latency_seconds_bucket[5m])) by (le, handler))",
          "refId": "A"
        }
      ],
      "title": "API Gateway P95 Latency",
      "type": "timeseries"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never"},
          "unit": "reconciliations/s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(KUBESYNAPSE_operator_reconcile_total[5m])) by (resource_type)",
          "refId": "A"
        }
      ],
      "title": "Operator Reconciliation Rate",
      "type": "timeseries"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
      "id": 5,
      "targets": [
        {
          "expr": "sum(KUBESYNAPSE_operator_reconcile_errors_total)",
          "refId": "A"
        }
      ],
      "title": "Operator Reconcile Errors",
      "type": "stat"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 2}]}
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
      "id": 6,
      "targets": [
        {
          "expr": "sum(KUBESYNAPSE_circuit_breaker_state{state=\"open\"})",
          "refId": "A"
        }
      ],
      "title": "Open Circuit Breakers",
      "type": "stat"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never"},
          "unit": "bytes"
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
      "id": 7,
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=~\"$namespace\", pod=~\"kubesynapse-.*\"}) by (pod)",
          "refId": "A"
        }
      ],
      "title": "Memory Usage by Pod",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
