{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "kubesynapse Agent Overview — agent health, pod status, resource usage, and CRD counts",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "Agent Health",
      "type": "row"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "count(kube_pod_info{namespace=\"$namespace\", pod=~\"kubesynapse-agent-.*\", phase=\"Running\"})",
          "legendFormat": "Running Agents"
        }
      ],
      "title": "Running Agents",
      "type": "stat"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "count(kube_pod_info{namespace=\"$namespace\", pod=~\"kubesynapse-agent-.*\", phase!=\"Running\", phase!=\"Succeeded\"})",
          "legendFormat": "Non-Running Agents"
        }
      ],
      "title": "Unhealthy Agents",
      "type": "stat"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 95}
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "(count(kube_pod_info{namespace=\"$namespace\", pod=~\"kubesynapse-agent-.*\", phase=\"Running\"}) / count(kube_pod_info{namespace=\"$namespace\", pod=~\"kubesynapse-agent-.*\"})) * 100",
          "legendFormat": "Health %"
        }
      ],
      "title": "Agent Health %",
      "type": "stat"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {
        "legend": {"calcs": ["last"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "expr": "count(kube_pod_info{namespace=\"$namespace\", pod=~\"kubesynapse-agent-.*\"}) by (phase)",
          "legendFormat": "{{phase}}"
        }
      ],
      "title": "Agents by Phase",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6},
      "id": 200,
      "panels": [],
      "title": "Resource Usage",
      "type": "row"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 15,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "mappings": [],
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 7},
      "id": 10,
      "options": {
        "legend": {"calcs": ["max", "mean"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"$namespace\", pod=~\"kubesynapse-agent-.*\", container!=\"\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ],
      "title": "Agent Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 15,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 7},
      "id": 11,
      "options": {
        "legend": {"calcs": ["max", "mean"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"kubesynapse-agent-.*\", container!=\"\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ],
      "title": "Agent CPU Usage (cores/sec)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17},
      "id": 300,
      "panels": [],
      "title": "CRD & Reconciliation",
      "type": "row"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "mappings": [],
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
      "id": 20,
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum(rate(KUBESYNAPSE_operator_reconcile_total[5m])) by (resource_type, status)",
          "legendFormat": "{{resource_type}}-{{status}}"
        }
      ],
      "title": "Reconciliation Rate (success/error)",
      "type": "timeseries"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 20,
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 30},
              {"color": "red", "value": 60}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "id": 21,
      "options": {
        "legend": {"calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(KUBESYNAPSE_operator_reconcile_duration_seconds_bucket[5m])) by (le, resource_type))",
          "legendFormat": "P95 {{resource_type}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(KUBESYNAPSE_operator_reconcile_duration_seconds_bucket[5m])) by (le, resource_type))",
          "legendFormat": "P50 {{resource_type}}"
        }
      ],
      "title": "Reconciliation Latency (P50/P95)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["kubesynapse", "agents"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "kubesynapse", "value": "kubesynapse"},
        "datasource": "${prometheus_datasource}",
        "definition": "label_values(kube_namespace_created, namespace)",
        "hide": 0,
        "includeAll": false,
        "label": "Namespace",
        "multi": false,
        "name": "namespace",
        "options": [],
        "query": "label_values(kube_namespace_created, namespace)",
        "refresh": 1,
        "regex": "/kubesynapse/",
        "sort": 0,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "kubesynapse — Agent Overview",
  "uid": "kubesynapse-agent-overview",
  "version": 1,
  "weekStart": ""
}
