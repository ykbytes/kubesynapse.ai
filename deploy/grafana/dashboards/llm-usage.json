        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "id": 20,
      "options": {
        "legend": {"calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "(sum(rate(KUBESYNAPSE_llm_requests_total{status=~\"5..|error\"}[5m])) by (provider) / sum(rate(KUBESYNAPSE_llm_requests_total[5m])) by (provider)) * 100",
          "legendFormat": "{{provider}} error %"
