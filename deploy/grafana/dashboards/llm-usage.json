      "id": 100,
      "panels": [],
      "title": "Usage Overview",
      "type": "row"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(KUBESYNAPSE_llm_requests_total[5m]))",
          "legendFormat": "req/s"
        }
      ],
      "title": "LLM Requests (req/s)",
      "type": "stat"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100000},
              {"color": "orange", "value": 500000},
              {"color": "red", "value": 1000000}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(KUBESYNAPSE_llm_tokens_total[5m]))",
          "legendFormat": "tokens/s"
        }
      ],
      "title": "Tokens/sec",
      "type": "stat"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(KUBESYNAPSE_llm_cost_dollars_total[5m])) * 3600",
          "legendFormat": "$/hr"
        }
      ],
      "title": "Cost Rate ($/hr)",
      "type": "stat"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "(sum(rate(KUBESYNAPSE_llm_requests_total{status=~\"5..|error\"}[5m])) / sum(rate(KUBESYNAPSE_llm_requests_total[5m]))) * 100",
          "legendFormat": "Error Rate"
        }
      ],
      "title": "Error Rate %",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 200,
      "panels": [],
      "title": "Token Usage & Cost by Model",
      "type": "row"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 15,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 6},
      "id": 10,
      "options": {
        "legend": {"calcs": ["max", "mean", "sum"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum(rate(KUBESYNAPSE_llm_tokens_total[5m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "title": "Token Rate by Model",
      "type": "timeseries"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 15,
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 6},
      "id": 11,
      "options": {
        "legend": {"calcs": ["max", "mean", "sum"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum(rate(KUBESYNAPSE_llm_cost_dollars_total[5m])) by (model) * 3600",
          "legendFormat": "{{model}} $/hr"
        }
      ],
      "title": "Cost Rate by Model ($/hr)",
      "type": "timeseries"
    },
    {
      "datasource": "${prometheus_datasource}",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 10,
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "P99"}, "properties": [{"id": "custom.lineStyle", "value": {"dash": [5, 5], "fill": "dash"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 12,
      "options": {
        "legend": {"calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(KUBESYNAPSE_llm_request_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "P50 {{model}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(KUBESYNAPSE_llm_request_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "P95 {{model}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(KUBESYNAPSE_llm_request_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "P99 {{model}}"
        }
      ],
      "title": "LLM Request Latency (P50/P95/P99 by model)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
