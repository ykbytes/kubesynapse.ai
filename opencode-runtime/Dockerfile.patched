FROM oven/bun:1.3.11 AS opencode-build

ARG OPENCODE_GIT_URL="https://github.com/ykbytes/opencode.git"
ARG OPENCODE_GIT_REF="fix/copilot-token-exchange"
ARG OPENCODE_GIT_COMMIT="f2b5e2abdc81ba4ac110fcbf7cc20203e33029e5"

WORKDIR /src

RUN apt-get update \
    && apt-get install -y --no-install-recommends git python3 make g++ ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 --branch "${OPENCODE_GIT_REF}" "${OPENCODE_GIT_URL}" repo

WORKDIR /src/repo

RUN if [ -n "${OPENCODE_GIT_COMMIT}" ]; then \
      git fetch --depth 1 origin "${OPENCODE_GIT_COMMIT}" && git checkout "${OPENCODE_GIT_COMMIT}"; \
    fi

RUN bun install --frozen-lockfile \
    --filter opencode \
    --filter @opencode-ai/plugin \
    --filter @opencode-ai/script \
    --filter @opencode-ai/sdk \
    --filter @opencode-ai/util
RUN cd packages/opencode && bun run build --single

RUN test -x /src/repo/packages/opencode/dist/opencode-linux-x64/bin/opencode


FROM python:3.12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends git nodejs npm curl unzip ca-certificates \
    && python3 -m venv /opt/venv \
    && rm -rf /var/lib/apt/lists/*

COPY --from=opencode-build /src/repo/packages/opencode/dist/opencode-linux-x64/bin/opencode /usr/local/bin/opencode

RUN BUN_VERSION="1.1.45" \
    && curl -fsSL https://bun.sh/install | bash -s "bun-v${BUN_VERSION}" \
    && mv /root/.bun /opt/bun \
    && ln -sf /opt/bun/bin/bun /usr/local/bin/bun

WORKDIR /app

COPY requirements.txt .
RUN /opt/venv/bin/pip install --no-cache-dir -r requirements.txt

COPY main.py hitl.py config.py tracing.py utils.py prompts.py models.py session.py skills.py opencode_client.py analysis.py invoke.py supervisor.py ./

RUN test -x /usr/local/bin/opencode && test -x /usr/local/bin/bun

RUN useradd --uid 1000 --create-home opencodeuser \
    && mkdir -p /app/state /workspace \
    && chown -R opencodeuser:opencodeuser /app /workspace

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH=/opt/venv/bin:/usr/local/bin:$PATH \
    HOME=/app/state/home \
    XDG_CONFIG_HOME=/app/state/home/.config \
    XDG_DATA_HOME=/app/state/home/.local/share \
    OPENCODE_CONFIG_DIR=/app/state/home/.config/opencode-profile \
    OPENCODE_BIN=/usr/local/bin/opencode \
    OPENCODE_WORKDIR=/workspace

USER opencodeuser

EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8080/ready', timeout=3)"

ENTRYPOINT ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080", "--proxy-headers", "--forwarded-allow-ips", "*"]
